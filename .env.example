# =================================
# UNIVERSAL BOOKING SYSTEM ENV
# =================================

# Application
NODE_ENV=production
PORT=3000

# Stripe Payments - Novo Modelo de Cobrança por Conversa
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_BASICO_PRICE_ID=price_basico_plan_id_here
STRIPE_PROFISSIONAL_PRICE_ID=price_profissional_plan_id_here
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_id_here

# Supabase Configuration
SUPABASE_URL=https://qsdfyffuonywmtnlycri.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (Local/Backup)
POSTGRES_DB=booking_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# Redis Cache
REDIS_PASSWORD=redis123

# N8N Configuration
N8N_DB=n8n
N8N_USER=admin
N8N_PASSWORD=admin123

# Monitoring
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# WhatsApp Business API
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=your-openai-org-id

# Email Service (Zoho SMTP)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=contato@suaempresa.com
ZOHO_SMTP_PASS=sua-app-password-zoho
EMAIL_FROM_NAME=Universal Booking System
EMAIL_FROM_ADDRESS=noreply@suaempresa.com
FRONTEND_URL=https://suaempresa.com

# Email Service (Zoho API - Optional)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# Email Configuration
ENABLE_EMAIL_SERVICE=true
ENABLE_EMAIL_REMINDERS=true
ENABLE_SUBSCRIPTION_MONITORING=true
ENABLE_ANALYTICS_SCHEDULER=true

# Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/google/oauth2callback

# Security & Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Airtable API
AIRTABLE_API_KEY=your-airtable-api-key
AIRTABLE_BASE_ID=your-airtable-base-id

# Security
JWT_SECRET=your-super-secret-jwt-key
ENCRYPTION_KEY=your-32-char-encryption-key

# Domain Configuration
DOMAIN=localhost
SSL_ENABLED=false